# ── LLM ──────────────────────────────────────────────────────────────────
# Choose your LLM provider: 'groq' or 'gemini'
LLM_PROVIDER=groq

# GROQ API key (get from https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# LLM model to use (depends on provider)
LLM_MODEL=gpt-oss-120b

# Sampling temperature (0.0 to 2.0)
LLM_TEMPERATURE=0.2

# ── Embeddings ────────────────────────────────────────────────────────────
# SentenceTransformer model name (local)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Store (ChromaDB) ───────────────────────────────────────────────
# Directory for ChromaDB persistence
CHROMA_PERSIST_DIR=./chroma_db

# ChromaDB collection name
CHROMA_COLLECTION=rag_docs

# ── Document Loading ───────────────────────────────────────────────────────
# Directory where user places PDFs/DOCX/TXT files
DOCUMENTS_DIR=./documents

# Approximate words per document chunk
CHUNK_SIZE=500

# Words to overlap between chunks
CHUNK_OVERLAP=50

# Enable folder watching for new documents
WATCH_ENABLED=True
