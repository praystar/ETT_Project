# Google Gemini API Configuration
# Get your free API key from: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your-actual-gemini-api-key-here

# LLM Configuration (optional - defaults shown)
# Available models: gemini-2.5-pro, gemini-1.5-flash, gemini-1.5-pro, gemini-1.5-pro-latest
LLM_MODEL=gemini-2.5-pro
LLM_TEMPERATURE=0.2

# Embeddings Configuration (optional - defaults shown)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector Store Configuration (optional - defaults shown)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=rag_docs
